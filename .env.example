# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_crypto

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRE=30d

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Cloudinary (File Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Redis (Session & Caching)
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# Admin Email
ADMIN_EMAIL=admin@yourdomain.com

# QR Code
QR_CODE_SIZE=200

# Session
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=86400000

# Crypto Wallet Addresses (examples - admin can change via dashboard)
BTC_WALLET_ADDRESS=1A1z7agoat2LWQLRZFR2MqkRUQucis3pj
ETH_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f42aE0
USDT_TRC20_WALLET_ADDRESS=TXrx9P7Q3m9f2D8xZ5kL1nW4bY6vJ8hP2
USDT_ERC20_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f42aE0
LTC_WALLET_ADDRESS=LRahCTYvFwZqTTz4ZwrKq38a5arKvDj2Ej
SOL_WALLET_ADDRESS=EPjFWaLb3hyMw2z9Zp6WQqJmYCCqnfLV8cxCBtq

# Security
CORS_ORIGIN=http://localhost:3000
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info
